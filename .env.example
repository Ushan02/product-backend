#MONGO_URL=mongodb://localhost:27017/your-db-name
#JWT_KEY=your-jwt-secret-key

#Google OAuth (same Client ID as frontend VITE_GOOGLE_CLIENT_ID)
#GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

#Gmail SMTP for password reset OTP
#SMTP_HOST=smtp.gmail.com
#SMTP_PORT=587
#SMTP_USER=your@gmail.com
#Use a Gmail App Password (not your login password). Quote values that contain # or spaces.
#SMTP_PASS="your-gmail-app-password"
#SMTP_FROM=your@gmail.com

#Payment: "free" = Cash on Delivery | "stripe" = online card payments
#PAYMENT_MODE=free
#FRONTEND_URL=http://localhost:5173

#Stripe (only when PAYMENT_MODE=stripe) — https://dashboard.stripe.com/apikeys
#STRIPE_SECRET_KEY=sk_test_...
#STRIPE_PUBLISHABLE_KEY=pk_test_...
